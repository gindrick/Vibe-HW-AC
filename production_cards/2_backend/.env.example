ENV=dev
LOG_LEVEL=INFO

# Auth
AUTH_MODE=ldap
DEV_AUTH_BYPASS=true
DEV_AUTH_USER_EMAIL=dev@hranipex.local
DEV_AUTH_USER_NAME=Dev User

# LDAP
LDAP_SERVER=ldap://dc.hranipex.local
LDAP_DOMAIN=hranipex.local
LDAP_ALLOWED_USERS=

# MSSQL
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=production_cards
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# LiteLLM proxy
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=sk-mysecretkey
LITELLM_MODEL=llm-default

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8011
BACKEND_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Frontend URL (for auth redirects)
FRONTEND_URL=http://127.0.0.1:5174/production_cards/

SESSION_SECRET=production-cards-change-this-secret
UPLOAD_ROOT=./storage/uploads
AUTO_CREATE_SCHEMA=true
PUBLIC_API_PREFIX=
