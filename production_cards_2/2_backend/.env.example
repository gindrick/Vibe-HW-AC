ENV=dev
LOG_LEVEL=INFO

# Auth
AUTH_MODE=ldap
DEV_AUTH_BYPASS=true
DEV_AUTH_USER_EMAIL=dev@hranipex.local
DEV_AUTH_USER_NAME=Dev User

# LDAP
LDAP_SERVER=ldap://dc.hranipex.local
LDAP_DOMAIN=hranipex.local
LDAP_ALLOWED_USERS=

# MSSQL
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=production_cards
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# Extraction pipeline: "litellm" (default, OpenAI-compatible) or "agent" (Claude multi-agent)
EXTRACTION_PIPELINE=litellm

# LiteLLM / OpenAI — použito pokud EXTRACTION_PIPELINE=litellm
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=dummy
LITELLM_MODEL=gpt-4o-mini

# Claude Agent SDK — použito pokud EXTRACTION_PIPELINE=agent
# Model se vybírá podle model_name z litellm_config.yaml, volání jde přes LiteLLM proxy.
# ANTHROPIC_API_KEY se načítá z kořenového .env nebo nastav zde:
# ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=anthropic-claude-sonnet-4
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8012
BACKEND_CORS_ORIGINS=http://127.0.0.1:5175,http://localhost:5175

# Frontend URL (for auth redirects)
FRONTEND_URL=http://127.0.0.1:5175/production_cards_2/

SESSION_SECRET=production-cards-2-change-this-secret
UPLOAD_ROOT=./storage/uploads
AUTO_CREATE_SCHEMA=true
PUBLIC_API_PREFIX=
