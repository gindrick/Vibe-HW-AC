# LiteLLM server keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
RUNPOD_API_KEY=

# LiteLLM gateway auth (must match LITELLM_MASTER_KEY)
LITELLM_API_KEY=sk-mysecretkey
LITELLM_MODEL=oai-gpt-4.1-nano

# App config (ollama_hrx)
LLM_PROVIDER=litellm
LITELLM_BASE_URL=http://0.0.0.0:4000

# Ollama fallback
OLLAMA_MODEL=gpt-oss:20b-cloud

# Retrieval
TOP_K=8
MIN_SCORE=2.5
