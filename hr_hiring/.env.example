# Shared
ENV=dev
LOG_LEVEL=INFO

# Auth
AUTH_MODE=entra
DEV_AUTH_BYPASS=true
DEV_AUTH_USER_EMAIL=hm@example.com
DEV_AUTH_USER_NAME=Demo Hiring Manager

# Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=
ENTRA_JWKS_URL=

# MSSQL
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=hr_eval
MSSQL_USER=sa
MSSQL_PASSWORD=yourStrong(!)Password
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# Paths
UPLOAD_ROOT=./storage/uploads

# LiteLLM
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=sk-local
LITELLM_MODEL=gpt-4o-mini

# MCP
MCP_MODE=local
MCP_SERVER_URL=http://127.0.0.1:8002/mcp

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8010
VITE_PUBLIC_BASE_PATH=/hr_hiring/
VITE_API_ROUTER_PATH=/hr_hiring_api
VITE_AUTH_MODE=dev
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_REDIRECT_PATH=/hr_hiring/
