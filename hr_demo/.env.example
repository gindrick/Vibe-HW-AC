# Dashboard auth settings
# Supported: ldap | none
AUTH_PROVIDER=ldap

# Long random secret for signed session cookie
SESSION_SECRET=replace-with-long-random-secret

# LDAP settings
LDAP_SERVER=hranipex.net
LDAP_DOMAIN=hranipex.net

# Comma-separated allowlist (username or email)
# If empty, all valid LDAP users are allowed
LDAP_ALLOWED_USERS=jindrich.jansa,petr.pazourek,eva.rablova,romana.basova

# Public path prefix behind router
DASHBOARD_PUBLIC_PREFIX=/dashboard

# Encryption key for encrypted dashboard HTML (.html2)
# Generate with: python scripts/encrypt_index_html.py --generate-key
DASHBOARD_CONTENT_KEY=
